<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>AutoFuzz Report - {{ report.profile_name }}</title>
<style>
  :root { color-scheme: light dark; }
  body { font-family: system-ui, sans-serif; max-width: 960px; margin: 2rem auto; padding: 0 1rem; line-height: 1.5; }
  h1, h2, h3 { line-height: 1.2; }
  table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
  th, td { border: 1px solid #8888; padding: 0.5rem; text-align: left; }
  .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 0.75rem; margin: 1rem 0; }
  .stat { border: 1px solid #8888; border-radius: 8px; padding: 0.75rem; }
  .stat .label { font-size: 0.85rem; opacity: 0.8; }
  .stat .value { font-size: 1.5rem; font-weight: 700; }
  .finding { border: 1px solid #8888; border-radius: 8px; padding: 1rem; margin: 1rem 0; }
  .sev { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 999px; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; }
  .sev-critical { background: #ffdcdc; color: #7a0000; }
  .sev-high { background: #ffe6d5; color: #8a3b00; }
  .sev-medium { background: #fff4cc; color: #7a5c00; }
  .sev-low { background: #e2f0ff; color: #0a4a7a; }
  .sev-info { background: #e6e6e6; color: #333; }
  pre { background: #8881; padding: 0.75rem; border-radius: 6px; overflow-x: auto; white-space: pre-wrap; word-break: break-word; }
</style>
</head>
<body>
  <h1>AutoFuzz Scan Report</h1>
  <p><strong>{{ report.profile_name }}</strong> &mdash; {{ report.engine }} engine</p>

  <h2>Executive Summary</h2>
  <div class="summary-grid">
    <div class="stat"><div class="label">Target</div><div class="value" style="font-size:1rem">{{ report.target }}</div></div>
    <div class="stat"><div class="label">Risk score</div><div class="value">{{ report.risk.score }}</div></div>
    <div class="stat"><div class="label">Total findings</div><div class="value">{{ report.findings|length }}</div></div>
    <div class="stat"><div class="label">Highest severity</div><div class="value" style="font-size:1rem">{{ report.risk.max_severity.value if report.risk.max_severity else "none" }}</div></div>
  </div>
  <p>
    Scan ID: <code>{{ report.scan_id }}</code><br>
    Started: {{ report.started_at }}<br>
    Completed: {{ report.completed_at or "in progress" }}
  </p>

  <h2>Findings by Severity</h2>
  <table>
    <tr><th>Severity</th><th>Count</th></tr>
    {% for sev, count in severity_counts %}
    <tr><td><span class="sev sev-{{ sev }}">{{ sev }}</span></td><td>{{ count }}</td></tr>
    {% endfor %}
  </table>

  <h2>Findings</h2>
  {% if not report.findings %}
    <p>No findings.</p>
  {% else %}
    {% for finding in sorted_findings %}
    <div class="finding">
      <span class="sev sev-{{ finding.severity.value }}">{{ finding.severity.value }}</span>
      <h3>{{ finding.title }}</h3>
      <p><strong>Plugin:</strong> {{ finding.plugin_id }} &middot; <strong>Target:</strong> {{ finding.target }} &middot; <strong>Discovered:</strong> {{ finding.discovered_at }}</p>
      <p>{{ finding.description }}</p>
      {% if finding.evidence %}<pre>{{ finding.evidence }}</pre>{% endif %}
    </div>
    {% endfor %}
  {% endif %}

  <h2>Scan Statistics</h2>
  {% if report.stats %}
  <table>
    <tr><th>Metric</th><th>Value</th></tr>
    {% for key, value in report.stats.items() %}
    <tr><td>{{ key }}</td><td>{{ value }}</td></tr>
    {% endfor %}
  </table>
  {% else %}
  <p>No statistics recorded.</p>
  {% endif %}

  <h2>Recommendations</h2>
  {% if report.findings %}
  <p>Review each finding above and address it according to severity, starting with Critical/High items. Re-run this profile after remediation to confirm the findings no longer reproduce.</p>
  {% else %}
  <p>No findings were produced by this scan's active plugins/mutators. This does not guarantee the absence of vulnerabilities outside this scan's configured scope.</p>
  {% endif %}
</body>
</html>
