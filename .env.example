# AutoFuzz environment configuration.
#
# AutoFuzz reads these directly from the process environment - it does not
# load a .env file itself. Copy this to `.env` and either `export` its
# contents into your shell, or pass it to Docker via
# `docker run --env-file .env ...` / `docker compose --env-file .env ...`
# (Compose also picks up a sibling `.env` automatically for variable
# substitution in docker-compose.yml, independent of this).
#
# Every variable below is read by autofuzz.core.config.AutoFuzzSettings and
# has a working default - none of this is required to run AutoFuzz.

# Directory for scan session checkpoints and `autofuzz history`/`resume`
# (default: ~/.autofuzz). Point this somewhere writable and persistent if
# running AutoFuzz in a container without a mounted volume there.
AUTOFUZZ_CONFIG_DIR=~/.autofuzz

# Default log level when neither -v nor -q is passed on the command line:
# DEBUG, INFO, WARNING, ERROR, or CRITICAL (default: INFO). CLI flags
# always override this.
AUTOFUZZ_LOG_LEVEL=INFO

# Emit structured JSON logs instead of human-readable console output -
# useful when AutoFuzz's logs are being collected by something else
# (default: false).
AUTOFUZZ_LOG_JSON=false
